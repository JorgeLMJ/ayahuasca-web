---
// src/pages/testimonios.astro

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Testimonials from '../components/Testimonials.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
---

<Layout
  title="Testimonios | Spirit of Amazonas — Experiencias Reales"
  description="Testimonios reales de participantes en los retiros de ayahuasca de Spirit of Amazonas. Más de 500 personas de 40 países han transformado sus vidas."
  lang="es"
>
  <Header />
  <main id="main-content">
    <section class="page-hero section--dark">
      <div class="container">
        <div class="ornament" style="justify-content:flex-start">
          <span class="ornament-text" style="color:var(--color-gold-pale)">Experiencias Reales</span>
        </div>
        <h1 style="color:var(--color-white); margin-bottom:1rem">Testimonios</h1>
        <p style="font-family:var(--font-display); font-size:1.15rem; font-style:italic; color:rgba(255,255,255,0.7)">
          Más de 500 personas de 40 países han transformado sus vidas con nosotros.
        </p>
      </div>
    </section>
    <Testimonials />
  </main>
  <Footer />
  <WhatsAppButton />
</Layout>

<style>
  .page-hero { background: linear-gradient(160deg, var(--color-jungle-deep), var(--color-jungle-dark)); padding: 6rem 0 4rem; }
</style>
