---
// src/pages/preguntas-frecuentes.astro

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FAQ from '../components/FAQ.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
---

<Layout
  title="Preguntas Frecuentes | Spirit of Amazonas — Retiros de Ayahuasca"
  description="Preguntas frecuentes sobre los retiros de ayahuasca de Spirit of Amazonas: seguridad, preparación, contraindicaciones, duración, precios y proceso de reserva."
  lang="es"
>
  <Header />
  <main id="main-content">
    <section class="page-hero section--dark">
      <div class="container">
        <div class="ornament" style="justify-content:flex-start">
          <span class="ornament-text" style="color:var(--color-gold-pale)">Tus Dudas Resueltas</span>
        </div>
        <h1 style="color:var(--color-white); margin-bottom:1rem">Preguntas Frecuentes</h1>
        <p style="font-family:var(--font-display); font-size:1.15rem; font-style:italic; color:rgba(255,255,255,0.7); max-width:600px">
          Todo lo que necesitas saber antes de tu retiro de ayahuasca con nosotros.
        </p>
      </div>
    </section>
    <FAQ />
  </main>
  <Footer />
  <WhatsAppButton />
</Layout>

<style>
  .page-hero { background: linear-gradient(160deg, var(--color-jungle-deep), var(--color-jungle-dark)); padding: 6rem 0 4rem; }
</style>
