---
// src/components/Hero.astro

interface Props {
  title?:    string;
  subtitle?: string;
  lang?:     string;
}

const {
  title    = 'Despierta Tu Espíritu',
  subtitle = 'Ceremonias de Ayahuasca auténticas en el corazón de la Amazonía. Transforma tu vida con sabiduría ancestral y facilitadores certificados.',
  lang     = 'es',
} = Astro.props;

const retreatsLink = lang === 'en' ? '/en/retreats' : lang === 'pt' ? '/pt/retiros' : '/retiros';
---

<section id="hero" class="hero" aria-label="Sección principal">
  <!-- Background layers -->
  <div class="hero-bg" aria-hidden="true">
    <div class="hero-bg-overlay"></div>
    <div class="hero-bg-pattern"></div>
  </div>

  <!-- Floating particles -->
  <div class="hero-particles" aria-hidden="true">
    {Array.from({length: 20}).map((_, i) => (
      <span
        class="particle"
        style={`--delay:${(i * 0.4) % 5}s; --x:${Math.round((i * 37 + 11) % 100)}%; --size:${4 + (i % 6)}px; --duration:${6 + (i % 4)}s`}
      ></span>
    ))}
  </div>

  <!-- Content -->
  <div class="container hero-content">
    <div class="hero-text">
      <!-- Badge -->
      <div class="hero-badge animate-fade-in-up">
        <span class="badge-dot" aria-hidden="true"></span>
        Facilitadores Certificados · Amazonía, Perú
      </div>

      <!-- Ornament -->
      <div class="hero-ornament animate-fade-in-up animate-fade-in-up-delay-1" aria-hidden="true">
        <span class="ornament-line"></span>
        <span class="ornament-symbol">✧</span>
        <span class="ornament-line"></span>
      </div>

      <!-- Main heading -->
      <h1 class="hero-title animate-fade-in-up animate-fade-in-up-delay-2">
        {title}
      </h1>

      <p class="hero-subtitle animate-fade-in-up animate-fade-in-up-delay-3">
        {subtitle}
      </p>

      <!-- Stats -->
      <div class="hero-stats animate-fade-in-up animate-fade-in-up-delay-4">
        <div class="stat">
          <span class="stat-number">+500</span>
          <span class="stat-label">Ceremonias</span>
        </div>
        <div class="stat-divider" aria-hidden="true">|</div>
        <div class="stat">
          <span class="stat-number">15+</span>
          <span class="stat-label">Años</span>
        </div>
        <div class="stat-divider" aria-hidden="true">|</div>
        <div class="stat">
          <span class="stat-number">40+</span>
          <span class="stat-label">Países</span>
        </div>
      </div>

      <!-- CTAs -->
      <div class="hero-ctas animate-fade-in-up" style="animation-delay:0.5s">
        <a href={retreatsLink} class="btn btn--primary hero-cta-primary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
          Ver Retiros
        </a>
       
      </div>

      <!-- Trust signals -->
      <div class="hero-trust animate-fade-in-up" style="animation-delay:0.6s">
        <span class="trust-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path d="M5 13l4 4L19 7"/>
          </svg>
          Ceremonias Seguras
        </span>
        <span class="trust-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path d="M5 13l4 4L19 7"/>
          </svg>
          Ambiente Sagrado
        </span>
        <span class="trust-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path d="M5 13l4 4L19 7"/>
          </svg>
          Apoyo Integral
        </span>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="scroll-hint" aria-label="Desplaza hacia abajo">
    <div class="scroll-hint-mouse">
      <div class="scroll-hint-wheel"></div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: var(--color-jungle-deep);
  }

  /* Background */
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-bg-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% 0%, rgba(45,106,63,0.35) 0%, transparent 70%),
      radial-gradient(ellipse 60% 50% at 80% 100%, rgba(201,148,26,0.12) 0%, transparent 60%),
      linear-gradient(160deg, #0a1a0f 0%, #122a19 40%, #0d1f12 100%);
  }

  /* Jungle-like texture pattern */
  .hero-bg-pattern {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 20% 30%, rgba(45,106,63,0.08) 0%, transparent 40%),
      radial-gradient(circle at 80% 60%, rgba(201,148,26,0.06) 0%, transparent 35%),
      radial-gradient(circle at 60% 10%, rgba(74,140,92,0.05) 0%, transparent 30%);
  }

  /* Particles */
  .hero-particles {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }

  .particle {
    position: absolute;
    left: var(--x);
    bottom: -10px;
    width: var(--size);
    height: var(--size);
    border-radius: 50%;
    background: rgba(201, 148, 26, 0.4);
    animation: floatParticle var(--duration) var(--delay) infinite ease-in-out;
  }

  @keyframes floatParticle {
    0% { transform: translateY(0) scale(1); opacity: 0.4; }
    50% { transform: translateY(-60vh) scale(0.6); opacity: 0.1; }
    100% { transform: translateY(-100vh) scale(0.3); opacity: 0; }
  }

  /* Content */
  .hero-content {
    position: relative;
    z-index: 2;
    padding-block: 8rem 6rem;
    max-width: 800px;
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
  }

  /* Badge */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 1rem;
    background: rgba(201, 148, 26, 0.12);
    border: 1px solid rgba(201, 148, 26, 0.3);
    border-radius: 9999px;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: var(--color-gold-pale);
    margin-bottom: 1.25rem;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-gold);
    animation: pulseDot 2s infinite;
    flex-shrink: 0;
  }

  @keyframes pulseDot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }

  /* Ornament */
  .hero-ornament {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }
  .ornament-line {
    flex: 0 0 40px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-gold-pale));
  }
  .ornament-line:last-child {
    background: linear-gradient(90deg, var(--color-gold-pale), transparent);
  }
  .ornament-symbol {
    color: var(--color-gold);
    font-size: 1rem;
  }

  /* Title */
  .hero-title {
    font-family: var(--font-heading);
    font-size: clamp(2.8rem, 7vw, 5.5rem);
    font-weight: 700;
    color: var(--color-white);
    line-height: 1.05;
    letter-spacing: -0.01em;
    margin-bottom: 1.5rem;
    font-style: italic;
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: rgba(255,255,255,0.72);
    line-height: 1.75;
    max-width: 600px;
    margin-bottom: 1.75rem;
  }

  /* Stats */
  .hero-stats {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }
  .stat { display: flex; flex-direction: column; align-items: center; }
  .stat-number {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-gold-light);
    line-height: 1;
  }
  .stat-label {
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    margin-top: 0.2rem;
  }
  .stat-divider {
    color: rgba(255,255,255,0.2);
    font-size: 1.5rem;
    font-weight: 100;
  }

  /* CTAs */
  .hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.75rem;
  }

  .hero-cta-primary,
  .hero-cta-wa {
    font-size: 1rem;
    padding: 0.95rem 2rem;
  }

  /* Trust */
  .hero-trust {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
  }
  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    color: rgba(255,255,255,0.55);
  }
  .trust-item svg { color: var(--color-gold); flex-shrink: 0; }

  /* Scroll hint */
  .scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    animation: floatY 2.5s ease-in-out infinite;
  }
  .scroll-hint-mouse {
    width: 22px;
    height: 36px;
    border: 2px solid rgba(255,255,255,0.3);
    border-radius: 11px;
    display: flex;
    justify-content: center;
    padding-top: 6px;
  }
  .scroll-hint-wheel {
    width: 3px;
    height: 8px;
    background: var(--color-gold-light);
    border-radius: 2px;
    animation: scrollWheel 1.5s ease-in-out infinite;
  }
  @keyframes scrollWheel {
    0% { transform: translateY(0); opacity: 1; }
    100% { transform: translateY(12px); opacity: 0; }
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero-content {
      padding-block: 6rem 4rem;
      text-align: center;
      align-items: center;
    }
    .hero-text { align-items: center; }
    .hero-stats { justify-content: center; }
    .hero-ctas { justify-content: center; }
    .hero-trust { justify-content: center; }
    .hero-badge { text-align: center; }
  }
</style>
